<Window x:Class="Astrolune.Desktop.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AstroLune"
        Width="520"
        Height="320"
        MinWidth="520"
        MinHeight="320"
        MaxWidth="520"
        MaxHeight="320"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="#111A2C"
        Topmost="True"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </Window.Resources>
    <Grid Margin="32">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Vertical" Width="420">
            <TextBlock Text="AstroLune" FontSize="28" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center" />
            <TextBlock Text="{Binding CurrentStep}" FontSize="14" Foreground="#D0D6E3" HorizontalAlignment="Center" Margin="0,10,0,0" />
            <ProgressBar Minimum="0" Maximum="1" Height="10" Margin="0,18,0,0" Value="{Binding Progress}" Background="#1F2A44" Foreground="#5EA3FF" />
            <TextBlock Text="{Binding Warning}" Foreground="#F6C66B" TextWrapping="Wrap" Margin="0,12,0,0" Visibility="{Binding HasWarning, Converter={StaticResource BoolToVisibility}}" />
            <TextBlock Text="{Binding Error}" Foreground="#FF6B6B" TextWrapping="Wrap" Margin="0,12,0,0" Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}" />
            <Button Content="Exit" Width="120" Margin="0,18,0,0" Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}" Click="OnExitClicked" />
        </StackPanel>
    </Grid>
</Window>
